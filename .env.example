# Server
PORT=8080
ENVIRONMENT=development
LOG_LEVEL=INFO
APP_TIMEZONE=Europe/Rome

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=manawise
# Optional: path to PEM file (cert + private key) for X.509 / Atlas authentication.
# Leave empty for standard password-based auth.
MONGODB_TLS_CERT_FILE=

# JWT
JWT_SECRET=change_me_in_production_min_32_chars
JWT_EXPIRY_HOURS=72

# Auth emails (optional; if missing, emails are disabled)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_KEY=
MAIL_FROM=
FRONTEND_RESET_PASSWORD_URL=
PASSWORD_RESET_TOKEN_TTL_MINUTES=30

# Scryfall
SCRYFALL_BASE_URL=https://api.scryfall.com

# LLM
# Supported providers: openai, gemini
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_MAX_TOKENS=1000

# AI routing mode:
# external_only | internal_only | hybrid_prefer_external | hybrid_prefer_internal
AI_MODE=hybrid_prefer_external
AI_INTERNAL_RULES_ENABLED=true

# Secondary provider (optional fallback)
LLM_SECONDARY_PROVIDER=
LLM_SECONDARY_API_KEY=
LLM_SECONDARY_BASE_URL=
LLM_SECONDARY_MODEL=

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Gemini (OpenAI-compatible endpoint)
GEMINI_API_KEY=
GEMINI_OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# Suggested Gemini model examples:
# LLM_PROVIDER=gemini
# LLM_MODEL=gemini-pro-latest

# Worker pool
WORKER_POOL_SIZE=20

# Analytics (optional)
ANALYTICS_PROVIDER=none
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com

# OTA
OTA_STORAGE_DIR=./ota-releases

# Discord bot
DISCORD_BOT_TOKEN=
MANAWISE_API_URL=http://localhost:8080
MANAWISE_BOT_JWT=
BOT_DEFAULT_FORMAT=commander

# EDH Impact Analysis (Card Power Level Scoring)
EDH_IMPACT_CACHE_TTL_HOURS=24
EDH_IMPACT_WEIGHTS_PRICE=0.4
EDH_IMPACT_WEIGHTS_EDHREC=0.5
EDH_IMPACT_WEIGHTS_REPRINT=0.1
