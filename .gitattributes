# Normalize line endings to LF in the repo, checkout as-is on all platforms
* text=auto eol=lf

# Go source files
*.go text eol=lf

# JS/TS/HTML/CSS
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.html text eol=lf
*.css text eol=lf
*.json text eol=lf

# Shell scripts
*.sh text eol=lf

# Windows scripts — keep CRLF
*.bat text eol=crlf
*.ps1 text eol=crlf

# Binaries
*.exe binary
*.png binary
*.jpg binary
*.gif binary
*.woff binary
*.woff2 binary
